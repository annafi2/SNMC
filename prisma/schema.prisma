generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

model Applicant {
  id               String  @id
  nama             String
  email            String  @unique
  jalur            String
  tanggalLahir     String
  essay            String?
  scoreIRT         Float?
  essayScoreIRT    Float?
  ujianCode        String?
  status           String  @default("Dalam Proses")
  tanggalSubmit    String
  stats            Json?
  roleMinecraft    String?
  sekolahMinecraft String?
  cbtBlocked       Boolean @default(false)
  cbtViolations    Int     @default(0)
}

model Setting {
  key   String @id
  value Json
}
